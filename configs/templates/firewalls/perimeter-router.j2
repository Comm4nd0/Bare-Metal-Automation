!
! ============================================================
!  BMA — {{ hostname }}
!  Role  : Perimeter Router / Zone-Based Firewall
!          inside/outside interfaces, OSPF, NAT,
!          per-mission-tenant zones, inter-zone policies.
!  Serial: {{ serial }}
!  Site  : {{ site_slug | upper }}
! ============================================================
!
hostname {{ hostname }}
ip domain name {{ domain_name }}
!
! ── Service hardening ────────────────────────────────────────
no service pad
service tcp-keepalives-in
service tcp-keepalives-out
service timestamps log datetime msec localtime show-timezone
service timestamps debug datetime msec localtime show-timezone
service password-encryption
no ip source-route
no ip gratuitous-arps
no ip finger
no ip http server
no ip http secure-server
no ip bootp server
no cdp run
!
! ── Local auth ───────────────────────────────────────────────
aaa new-model
{% if tacacs_key %}
tacacs server TACACS-PRIMARY
 address ipv4 {{ ad_server }}
 key {{ tacacs_key }}
 timeout 5
!
aaa group server tacacs+ BMA-TACACS
 server name TACACS-PRIMARY
!
aaa authentication login default group BMA-TACACS local
aaa authorization exec default group BMA-TACACS local if-authenticated
aaa accounting exec default start-stop group BMA-TACACS
{% else %}
aaa authentication login default local
{% endif %}
!
username admin privilege 15 secret {{ enable_secret }}
enable secret {{ enable_secret }}
!
! ── SSH ──────────────────────────────────────────────────────
crypto key generate rsa modulus 2048
ip ssh version 2
ip ssh time-out 60
ip ssh authentication-retries 3
!
! ── NTP ──────────────────────────────────────────────────────
{% for ntp in ntp_servers %}
ntp server {{ ntp }} prefer
{% endfor %}
clock timezone UTC 0 0
!
! ── DNS ──────────────────────────────────────────────────────
{% for dns in dns_servers %}
ip name-server {{ dns }}
{% endfor %}
!
! ── Logging ──────────────────────────────────────────────────
{% if syslog_server %}
logging host {{ syslog_server }}
logging trap informational
{% endif %}
logging buffered 16384
no logging console
!
! ── SNMP ─────────────────────────────────────────────────────
{% if snmp_community_ro %}
snmp-server community {{ snmp_community_ro }} RO
snmp-server contact BMA-NOC
snmp-server location {{ site_slug | upper }}-PERIMETER
{% endif %}
!
! ============================================================
!  Interfaces
! ============================================================
!
! Outside interface (WAN / transit)
{% for iface in interfaces if 'outside' in iface.description | lower or 'wan' in iface.description | lower %}
interface {{ iface.name }}
 description {{ iface.description }} — OUTSIDE
 {% if iface.ip_address %}ip address {{ iface.ip_address }} {{ iface.ip_mask }}{% endif %}
 ip nat outside
 ip virtual-reassembly in
 no shutdown
!
{% endfor %}
!
! Inside interface (trunk to core)
{% for iface in interfaces if 'inside' in iface.description | lower or 'core' in iface.description | lower %}
interface {{ iface.name }}
 description {{ iface.description }} — INSIDE
 no shutdown
!
{% for vlan in vlans if vlan.is_management %}
interface {{ iface.name }}.{{ vlan.vid }}
 encapsulation dot1Q {{ vlan.vid }}
 {% if vlan.vid == 100 %}ip address {{ mgmt_ip }} {{ mgmt_mask }}{% endif %}
 ip nat inside
 no shutdown
!
{% endfor %}
{% for tenant in mission_tenants %}
interface {{ iface.name }}.{{ tenant.user_vlan }}
 encapsulation dot1Q {{ tenant.user_vlan }}
{% if tenant.user_gateway %}
 ip address {{ tenant.user_gateway }} {{ tenant.user_mask }}
{% endif %}
 no shutdown
!
{% endfor %}
{% endfor %}
!
! Management interface (OOB)
interface Loopback0
 description ROUTER-ID
 ip address {{ mgmt_ip }} 255.255.255.255
 no shutdown
!
! ============================================================
!  OSPF
! ============================================================
!
router ospf 1
 router-id {{ mgmt_ip }}
 passive-interface default
{% for iface in interfaces if 'outside' not in iface.description | lower %}
 no passive-interface {{ iface.name }}
{% endfor %}
 network {{ mgmt_ip }} 0.0.0.0 area 0
 default-information originate always
 area 0 authentication message-digest
!
! ── Default route from WAN ────────────────────────────────────
ip route 0.0.0.0 0.0.0.0 {{ mgmt_gateway }}
!
! ============================================================
!  NAT — PAT for internal subnets to outside interface
! ============================================================
!
ip nat inside source list NAT-INSIDE interface
{%- for iface in interfaces if 'outside' in iface.description | lower or 'wan' in iface.description | lower %} {{ iface.name }}{% endfor %} overload
!
ip access-list standard NAT-INSIDE
 remark Management subnets
 permit 10.0.0.0 0.255.255.255
{% for tenant in mission_tenants %}
{% if tenant.user_subnet %}
 permit {{ tenant.user_subnet }} 0.0.0.255
{% endif %}
{% if tenant.apps_subnet %}
 permit {{ tenant.apps_subnet }} 0.0.0.255
{% endif %}
{% if tenant.data_subnet %}
 permit {{ tenant.data_subnet }} 0.0.0.255
{% endif %}
{% endfor %}
!
! ============================================================
!  Zone-Based Firewall (ZBF)
! ============================================================
!
! ── Define zones ─────────────────────────────────────────────
zone security OUTSIDE
zone security MGMT
{% for tenant in mission_tenants %}
zone security MISSION{{ tenant.index }}
{% endfor %}
!
! ── Assign interfaces to zones ───────────────────────────────
{% for iface in interfaces if 'outside' in iface.description | lower or 'wan' in iface.description | lower %}
interface {{ iface.name }}
 zone-member security OUTSIDE
!
{% endfor %}
!
{% for iface in interfaces if 'inside' in iface.description | lower or 'core' in iface.description | lower %}
{% for vlan in vlans if vlan.is_management %}
interface {{ iface.name }}.{{ vlan.vid }}
 zone-member security MGMT
!
{% endfor %}
{% for tenant in mission_tenants %}
interface {{ iface.name }}.{{ tenant.user_vlan }}
 zone-member security MISSION{{ tenant.index }}
!
{% endfor %}
{% endfor %}
!
! ── Class maps ───────────────────────────────────────────────
class-map type inspect match-any CM-MGMT-SERVICES
 match protocol ssh
 match protocol snmp
 match protocol ntp
!
class-map type inspect match-any CM-DNS-NTP
 match protocol dns
 match protocol ntp
!
class-map type inspect match-any CM-AD
 match protocol ldap
 match protocol kerberos
 match protocol msrpc
!
class-map type inspect match-any CM-WEB
 match protocol http
 match protocol https
!
! ── Policy maps ──────────────────────────────────────────────
!
! Mission → MGMT: allow DNS, NTP, AD only
policy-map type inspect PM-MISSION-TO-MGMT
 class type inspect CM-DNS-NTP
  inspect
 class type inspect CM-AD
  inspect
 class class-default
  drop log
!
! Mission → Outside: allow web
policy-map type inspect PM-MISSION-TO-OUTSIDE
 class type inspect CM-WEB
  inspect
 class class-default
  drop log
!
! Mission → Mission: deny all (no inter-tenant traffic)
policy-map type inspect PM-MISSION-TO-MISSION
 class class-default
  drop log
!
! MGMT → Any: full inspect
policy-map type inspect PM-MGMT-TO-ANY
 class class-default
  inspect
!
! Outside → MGMT: SSH only (for jump-host access)
policy-map type inspect PM-OUTSIDE-TO-MGMT
 class type inspect CM-MGMT-SERVICES
  inspect
 class class-default
  drop log
!
! ── Zone pairs ───────────────────────────────────────────────
zone-pair security ZP-MGMT-TO-ANY source MGMT destination any
 service-policy type inspect PM-MGMT-TO-ANY
!
zone-pair security ZP-OUTSIDE-TO-MGMT source OUTSIDE destination MGMT
 service-policy type inspect PM-OUTSIDE-TO-MGMT
!
{% for tenant in mission_tenants %}
zone-pair security ZP-MISSION{{ tenant.index }}-TO-MGMT source MISSION{{ tenant.index }} destination MGMT
 service-policy type inspect PM-MISSION-TO-MGMT
!
zone-pair security ZP-MISSION{{ tenant.index }}-TO-OUTSIDE source MISSION{{ tenant.index }} destination OUTSIDE
 service-policy type inspect PM-MISSION-TO-OUTSIDE
!
{% for other in mission_tenants if other.index != tenant.index %}
zone-pair security ZP-MISSION{{ tenant.index }}-TO-MISSION{{ other.index }} source MISSION{{ tenant.index }} destination MISSION{{ other.index }}
 service-policy type inspect PM-MISSION-TO-MISSION
!
{% endfor %}
{% endfor %}
!
! ============================================================
!  Console and VTY
! ============================================================
!
banner motd ^
*******************************************************************************
*  AUTHORIZED ACCESS ONLY — {{ hostname | upper }}                            *
*  Perimeter Router — {{ site_slug | upper }}                                 *
*  Unauthorized access is prohibited.                                         *
*******************************************************************************
^
!
line con 0
 exec-timeout 10 0
 logging synchronous
 transport preferred none
!
line vty 0 15
 exec-timeout 15 0
 logging synchronous
 transport input ssh
 transport output none
 login authentication default
!
end
